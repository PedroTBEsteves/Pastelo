  m_SharedData: {fileID: 11400000, guid: 190d5a78372d24045ba36df6a0634436, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 4565938176
    m_Localized: "Eu esperei, acreditei\u2026 e fui enganado de novo, cl\xE1ssico."
    m_Metadata:
      m_Items: []
  - m_Id: 24446939136
    m_Localized: "Meu pedido virou lenda urbana, todo mundo fala mas ningu\xE9m v\xEA."
    m_Metadata:
      m_Items: []
  - m_Id: 41291264000
    m_Localized: "Nossa, que rapidez\u2026 quase achei que ia sair hoje com o pastel."
    m_Metadata:
      m_Items: []
  - m_Id: 74992496640
    m_Localized: Tranquilo, eu nem queria comer mesmo.
    m_Metadata:
      m_Items: []
  - m_Id: 81451724800
    m_Localized: Sem pressa, eu claramente tenho o dia todo pra isso.
    m_Metadata:
      m_Items: []
  - m_Id: 111722016768
    m_Localized: "T\xE1 de boa, fome \xE9 psicol\xF3gico."
    m_Metadata:
      m_Items: []
  - m_Id: 122606235648
    m_Localized: Pedi um pastel e ganhei um lembrete de que esperar nunca vale a
      pena.
    m_Metadata:
      m_Items: []
  - m_Id: 147558150144
    m_Localized: "O pedido n\xE3o chegou, mas a decep\xE7\xE3o sempre chega pontualmente."
    m_Metadata:
      m_Items: []
  references:
