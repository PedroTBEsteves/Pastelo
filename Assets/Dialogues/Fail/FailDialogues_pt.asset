  m_TableData:
  - m_Id: 4230393856
    m_Localized: "O recheio foi sequestrado? Porque n\xE3o achei ele aqui."
    m_Metadata:
      m_Items: []
  - m_Id: 36560089088
    m_Localized: "Se o objetivo era me vender vento gourmet, parab\xE9ns."
    m_Metadata:
      m_Items: []
  - m_Id: 83129446400
    m_Localized: "T\xE1 t\xE3o oleoso que d\xE1 pra fritar outro pastel com esse
      aqui."
    m_Metadata:
      m_Items: []
  - m_Id: 89508982784
    m_Localized: "N\xE3o lembro de ter pedido pastel sabor de decep\xE7\xE3o."
    m_Metadata:
      m_Items: []
  - m_Id: 106894372864
    m_Localized: "Se esse \xE9 o \u201Csabor da casa\u201D, a casa est\xE1 precisando
      de uma reforma."
    m_Metadata:
      m_Items: []
