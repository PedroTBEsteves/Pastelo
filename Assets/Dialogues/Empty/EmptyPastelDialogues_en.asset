  m_TableData:
  - m_Id: 3538333696
    m_Localized: I want an empty pastel, just like my functional adult skills.
    m_Metadata:
      m_Items: []
  - m_Id: 6453374976
    m_Localized: I want a pastel with nothing in it, just like my bank account.
    m_Metadata:
      m_Items: []
  - m_Id: 10236637184
    m_Localized: An air-filled pastel, just like my hopes on a Monday.
    m_Metadata:
      m_Items: []
  - m_Id: 18646216704
    m_Localized: Give me a pastel with the same filling as my love life - nonexistent.
    m_Metadata:
      m_Items: []
  - m_Id: 22974738432
    m_Localized: "A pastel with no filling, to match my resum\xE9."
    m_Metadata:
      m_Items: []
