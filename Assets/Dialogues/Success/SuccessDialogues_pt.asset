  m_TableData:
  - m_Id: 84018638848
    m_Localized: "Nunca confiei em ningu\xE9m como confio nesse pastel."
    m_Metadata:
      m_Items: []
  - m_Id: 96295366656
    m_Localized: "Pastel t\xE3o bom que at\xE9 o \xF3leo deve ser gourmet."
    m_Metadata:
      m_Items: []
  - m_Id: 100380618752
    m_Localized: "J\xE1 t\xF4 pensando em casar com o cozinheiro."
    m_Metadata:
      m_Items: []
  - m_Id: 104432316416
    m_Localized: Esse pastel curou traumas que nem terapia resolve.
    m_Metadata:
      m_Items: []
  - m_Id: 107779371008
    m_Localized: O pastel chegou quentinho e destruiu minha dieta em 3 segundos.
    m_Metadata:
      m_Items: []
  - m_Id: 113324240896
    m_Localized: "Esse pastel \xE9 meu novo motivo pra acreditar na humanidade."
    m_Metadata:
      m_Items: []
  - m_Id: 120328728576
    m_Localized: Comi e esqueci todos os meus problemas, inclusive os boletos.
    m_Metadata:
      m_Items: []
  - m_Id: 133473677312
    m_Localized: "Esse pastel \xE9 a prova de que Deus existe e frita bem."
    m_Metadata:
      m_Items: []
  - m_Id: 144441782272
    m_Localized: "Pastel t\xE3o bom que devia vir com trilha sonora de novela."
    m_Metadata:
      m_Items: []
  references:
    version: 2
