  m_TableData:
  - m_Id: 5270581248
    m_Localized: Is the pastel coming all the way from the North Pole on foot?
    m_Metadata:
      m_Items: []
  - m_Id: 10018533376
    m_Localized: Is the pastel frying, or is it in culinary school?
    m_Metadata:
      m_Items: []
  - m_Id: 14279946240
    m_Localized: "I\u2019ve aged two years waiting for this pastel."
    m_Metadata:
      m_Items: []
  - m_Id: 18558136320
    m_Localized: "Is it taking so long because you\u2019re growing the ingredients?"
    m_Metadata:
      m_Items: []
  - m_Id: 27420700672
    m_Localized: "It\u2019s being delivered by a turtle, right?"
    m_Metadata:
      m_Items: []
